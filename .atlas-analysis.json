  "keyFeatures": [
    "Type-safe TypeScript API with full inference",
    "Zod schema validation for data integrity",
    "Built-in soft delete functionality",
    "Lifecycle hooks for custom logic",
    "Powerful chainable query builder",
    "Transaction support with ACID guarantees",
    "Subcollection management",
    "Dot notation for nested field updates",
    "Bulk operations with automatic batching",
    "Real-time subscriptions and streaming"
  ],
